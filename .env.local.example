# Copy to .env.local, fill in, save, then restart `npm run dev`.
# Key from https://aistudio.google.com/apikey — should look like AIzaSy... (not gen-lang-client-...).
GEMINI_API_KEY=
# Optional alias (Google docs): GOOGLE_API_KEY=

# Optional: Cloud Vision OCR; if unset, Gemini reads the JPEG directly.
# VISION_API_KEY=
